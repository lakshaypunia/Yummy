generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String           @id @default(cuid())
  clerkId      String           @unique
  email        String           @unique
  firstName    String?
  lastName     String?
  fullName     String?
  avatarUrl    String?
  role         UserRole         @default(STUDENT)
  permissions  Json?
  progress     Json?
  preferences  Json?
  plan         SubscriptionPlan @default(FREE)
  credits      Int              @default(0)
  deletedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  chats        Chat[]
  documents    Document[]
  lectures     Lecture[]
  p5Animations P5Animation[]
  pages        Page[]
  spaces       Space[]
  joinedSpaces SpaceMember[]    @relation("UserJoinedSpaces")
}

model Space {
  id                      String                  @id @default(uuid())
  name                    String
  description             String?
  timeline                SpaceTimeline
  visibility              SpaceVisibility         @default(PRIVATE)
  authorId                String
  goal                    String
  skillLevel              SkillLevel
  tags                    String[]
  learningStyle           LearningStyle
  contentFormatPreference ContentFormatPreference
  depthPreference         DepthPreference
  resources               String[]
  project_roadmap         Json
  deletedAt               DateTime?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  chats                   Chat[]
  documents               Document[]
  lectures                Lecture[]
  pages                   Page[]
  author                  User                    @relation(fields: [authorId], references: [clerkId], onDelete: Cascade)
  members                 SpaceMember[]           @relation("SpaceMembers")
  whiteboard              Whiteboard?

  @@index([authorId])
  @@index([goal])
  @@index([skillLevel])
  @@index([visibility])
}

model Whiteboard {
  id        String   @id @default(uuid())
  spaceId   String   @unique
  elements  Json?
  appState  Json?
  files     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model SpaceMember {
  id        String          @id @default(uuid())
  spaceId   String
  userId    String
  role      SpaceMemberRole @default(MEMBER)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  space     Space           @relation("SpaceMembers", fields: [spaceId], references: [id], onDelete: Cascade)
  user      User            @relation("UserJoinedSpaces", fields: [userId], references: [clerkId], onDelete: Cascade)

  @@unique([spaceId, userId])
  @@index([userId])
  @@index([spaceId])
}

model Page {
  id              String         @id @default(uuid())
  title           String
  rawDocument     Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  authorId        String
  deletedAt       DateTime?
  depth           Int            @default(0)
  parentPageId    String?
  spaceId         String
  blockJson       Json?
  isIntialised    Boolean        @default(false)
  isRead          Boolean        @default(false)
  visibility      PageVisibility @default(EDITABLE)
  cacheExpiresAt  DateTime?
  geminiCacheName String?
  geminiFileUri   String?
  blocks          Block[]        @relation("PageBlocks")
  linkedFrom      Block[]        @relation("BlockTargetPage")
  author          User           @relation(fields: [authorId], references: [clerkId], onDelete: Cascade)
  parentPage      Page?          @relation("PageChildren", fields: [parentPageId], references: [id])
  childPages      Page[]         @relation("PageChildren")
  space           Space          @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([parentPageId])
  @@index([spaceId])
  @@index([createdAt])
  @@index([parentPageId, createdAt])
}

model Block {
  id            String   @id @default(uuid())
  pageId        String
  parentBlockId String?
  targetPageId  String?
  type          String
  content       Json?
  position      Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  page          Page     @relation("PageBlocks", fields: [pageId], references: [id], onDelete: Cascade)
  parentBlock   Block?   @relation("BlockChildren", fields: [parentBlockId], references: [id])
  children      Block[]  @relation("BlockChildren")
  targetPage    Page?    @relation("BlockTargetPage", fields: [targetPageId], references: [id])

  @@index([pageId, position])
  @@index([targetPageId])
}

model Chat {
  id        String     @id @default(uuid())
  spaceId   String
  userId    String
  title     String?
  status    ChatStatus @default(ACTIVE)
  context   Json?
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  space     Space      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  messages  Message[]

  @@index([spaceId])
  @@index([userId])
  @@index([spaceId, userId])
  @@index([status])
}

model Message {
  id          String      @id @default(uuid())
  chatId      String
  role        MessageRole
  content     String
  attachments Json?
  tokenCount  Int?
  isComplete  Boolean     @default(true)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  metadata    Json?
  chat        Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@index([chatId, role])
}

model P5Animation {
  id        String   @id @default(uuid())
  code      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)

  @@index([userId])
}

model Document {
  id        String   @id @default(uuid())
  name      String
  url       String
  key       String
  size      Int
  type      String
  spaceId   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [clerkId], onDelete: Cascade)
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
  @@index([authorId])
}

model Lecture {
  id          String   @id @default(uuid())
  title       String
  videoUrl    String
  description String?
  spaceId     String
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User     @relation(fields: [authorId], references: [clerkId], onDelete: Cascade)
  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
  @@index([authorId])
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SpaceTimeline {
  SPRINT
  PROJECT
  LEARNING_PATH
  CONTINUOUS
}

enum SpaceVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum ContentFormatPreference {
  TEXT_FOCUSED
  VIDEO_FOCUSED
  INTERACTIVE
  HYBRID
}

enum DepthPreference {
  SUMMARY
  CONCISE
  BALANCED
  DETAILED
  DEEP_DIVE
}

enum LearningStyle {
  SELF_PACED
  SPRINT_BASED
  STRUCTURED_PATH
  PROJECT_BASED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SpaceMemberRole {
  ADMIN
  MEMBER
}

enum PageVisibility {
  PRIVATE
  VIEW_ONLY
  EDITABLE
}

enum MessageRole {
  USER
  SYSTEM
}

enum ChatStatus {
  ACTIVE
  ARCHIVED
  DELETED
}
