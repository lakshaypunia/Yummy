INPUT: {
  "pageId": "970d71a6-4d6e-482a-8457-68c2c80e6562",
  "blockType": "blocks",
  "data": [
    {
      "type": "heading",
      "props": {
        "level": 1
      },
      "content": "React: A JavaScript Library for Building User Interfaces"
    },
    {
      "type": "paragraph",
      "content": "React is a free and open-source front-end JavaScript library for building user interfaces based on UI components. It is maintained by Meta and a community of individual developers and companies."
    },
    {
      "type": "heading",
      "props": {
        "level": 2
      },
      "content": "Key Concepts"
    },
    {
      "type": "bulletListItem",
      "content": [
        {
          "type": "text",
          "text": "Components: "
        },
        {
          "type": "text",
          "text": "Reusable, self-contained blocks of code that return React elements to describe what should appear on the screen.",
          "styles": {
            "italic": true
          }
        }
      ]
    },
    {
      "type": "bulletListItem",
      "content": [
        {
          "type": "text",
          "text": "JSX: "
        },
        {
          "type": "text",
          "text": "A syntax extension for JavaScript, allowing you to write HTML-like code within JavaScript files. It's not required but highly recommended.",
          "styles": {
            "italic": true
          }
        }
      ]
    },
    {
      "type": "bulletListItem",
      "content": [
        {
          "type": "text",
          "text": "State & Props: "
        },
        {
          "type": "text",
          "text": "Props are used to pass data from parent to child components (read-only). State is internal data managed by a component, allowing it to change over time.",
          "styles": {
            "italic": true
          }
        }
      ]
    },
    {
      "type": "bulletListItem",
      "content": [
        {
          "type": "text",
          "text": "Virtual DOM: "
        },
        {
          "type": "text",
          "text": "A lightweight copy of the actual DOM. React compares the Virtual DOM with the actual DOM to find the most efficient way to update the user interface, improving performance.",
          "styles": {
            "italic": true
          }
        }
      ]
    },
    {
      "type": "heading",
      "props": {
        "level": 2
      },
      "content": "Why Use React?"
    },
    {
      "type": "bulletListItem",
      "content": [
        {
          "type": "text",
          "text": "Declarative Syntax: "
        },
        {
          "type": "text",
          "text": "React makes it easier to create interactive UIs. Design simple views for each state in your application, and React will efficiently update and render just the right components when your data changes.",
          "styles": {
            "italic": true
          }
        }
      ]
    },
    {
      "type": "bulletListItem",
      "content": [
        {
          "type": "text",
          "text": "Component-Based: "
        },
        {
          "type": "text",
          "text": "Build encapsulated components that manage their own state, then compose them to make complex UIs.",
          "styles": {
            "italic": true
          }
        }
      ]
    },
    {
      "type": "bulletListItem",
      "content": [
        {
          "type": "text",
          "text": "Efficiency: "
        },
        {
          "type": "text",
          "text": "By using a Virtual DOM, React minimizes direct manipulation of the browser's DOM, leading to faster updates and a smoother user experience.",
          "styles": {
            "italic": true
          }
        }
      ]
    },
    {
      "type": "bulletListItem",
      "content": [
        {
          "type": "text",
          "text": "Strong Community & Ecosystem: "
        },
        {
          "type": "text",
          "text": "React has a vast and active community, meaning abundant resources, tutorials, and third-party libraries are available.",
          "styles": {
            "italic": true
          }
        }
      ]
    }
  ]
}
